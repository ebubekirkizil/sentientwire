generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Article {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  summary       String
  content       String
  category      String   @default("UNCLASSIFIED")
  categoryColor String   @default("#06b6d4")
  imageUrl      String?  // optional URL for article thumbnail
  locale        String   // 'en', 'es', 'de' vb.
  originalUrl   String?  // Kaynak URL (Hangi sızıntıdan/haberden çekildiği)
  isPublished   Boolean  @default(true)
  xPosted       Boolean  @default(false)
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([locale])
}

model PageVisit {
  id        String   @id @default(uuid())
  url       String
  referrer  String?
  country   String?
  ipHash    String?  // Privacy-friendly way to count unique visitors
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([url])
}

model SiteSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
